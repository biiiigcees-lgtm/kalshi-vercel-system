# Kalshi API Configuration
# Copy this file to .env and fill in your values

# Your Kalshi API Key ID (provided in dashboard)
KALSHI_API_KEY_ID=your-api-key-id-here

# Your RSA private key as a single line with \n for line breaks
# Format: paste the full PEM, replacing actual newlines with literal \n
KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# Set to "true" for demo (testnet), "false" for production (real money!)
KALSHI_DEMO=true

# A secure random string used to authorize Vercel Cron calls
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here